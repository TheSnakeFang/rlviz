{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rlviz.dev/schemas/v1alpha1/plugin-manifest.schema.json",
  "title": "RLViz plugin manifest",
  "type": "object",
  "required": ["api_version", "kind", "name", "version", "command", "capabilities"],
  "properties": {
    "api_version": { "const": "rlviz.dev/v1alpha1" },
    "kind": { "enum": ["Adapter", "Analyzer"] },
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["adapter.probe", "adapter.stream", "analyzer.analyze"] }
    },
    "description": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "Adapter" } }, "required": ["kind"] },
      "then": {
        "properties": {
          "capabilities": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "contains": { "const": "adapter.probe" },
            "allOf": [{ "contains": { "const": "adapter.stream" } }]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "Analyzer" } }, "required": ["kind"] },
      "then": {
        "properties": {
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": { "const": "analyzer.analyze" }
          }
        }
      }
    }
  ]
}
